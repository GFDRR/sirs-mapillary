# Copy to .env and fill in. .env is gitignored.
MAPILLARY_TOKEN=MLY|YOUR_APP_ID|YOUR_CLIENT_TOKEN

# For a public deploy, keep the token out of the browser and point the app at
# the Cloudflare Worker proxy instead (see DEPLOY.md). Leave unset for local dev.
# MLY_PROXY_BASE=https://your-worker.workers.dev
